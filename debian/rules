#!/usr/bin/make -f
# -*- makefile -*-
#
# See docs/phase-1.md §7.2 for the rationale. dh-cmake with
# cmake+ninja; system integration on; tests off (Phase 1 has none yet).

include /usr/share/dpkg/architecture.mk

export DEB_BUILD_MAINT_OPTIONS = hardening=+all
export DEB_LDFLAGS_MAINT_APPEND = -Wl,--as-needed
# CMake 4.x policy-range escape hatch — same one we use in the KSH
# backport. Harmless under 3.28 (Noble stock), keeps us Resolute-ready.
export CMAKE_POLICY_VERSION_MINIMUM = 3.5

%:
	dh $@ --buildsystem=cmake+ninja

override_dh_auto_configure:
	dh_auto_configure -- \
	    -DCMAKE_BUILD_TYPE=RelWithDebInfo \
	    -DCLAUDEQT_SYSTEM_INTEGRATION=ON \
	    -DCLAUDEQT_BUILD_REMOTE=ON \
	    -DBUILD_TESTING=OFF

override_dh_auto_test:
	# No tests built in Phase 1.

override_dh_missing:
	dh_missing --fail-missing
