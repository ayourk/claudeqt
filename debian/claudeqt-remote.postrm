#!/bin/sh
set -e

case "$1" in
    purge)
        # Remove user+group+home ONLY on purge, never on plain remove.
        # This wipes the user's Claude CLI install and session state.
        if getent passwd claudeqt >/dev/null; then
            deluser --system --quiet claudeqt || true
        fi
        if getent group claudeqt >/dev/null; then
            delgroup --system --quiet claudeqt || true
        fi
        rm -rf /var/lib/claudeqt /etc/claudeqt
        ;;
    remove|upgrade|failed-upgrade|abort-install|abort-upgrade|disappear)
        # Keep user, home, config, and certs across remove/upgrade cycles.
        ;;
esac

#DEBHELPER#

exit 0
