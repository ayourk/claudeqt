# ---- debhelper / dh_* byproducts inside debian/ ----
# The KSH Qt6 backport source package lives in a sibling directory
# outside this git root, so its debhelper staging directories never
# appear here. Only the main claudeqt source package writes into
# this tree's debian/.
debian/.debhelper/
debian/files
debian/debhelper-build-stamp
debian/*.debhelper.log
debian/*.debhelper
debian/*.substvars
debian/tmp/
debian/claudeqt/
debian/claudeqt-remote/
debian/claudeqt-common/

# ---- Python caches (if the embedded bridge ever grows a sidecar) ----
__pycache__/
*.pyc
*.pyo
.venv/
.mypy_cache/
.pytest_cache/
.ruff_cache/

# ---- Claude Code per-user settings ----
