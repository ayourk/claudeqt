# ---- debhelper / dh_* byproducts inside debian/ ----
# The KSH Qt6 backport source package lives in
# /wd8tb/ai/claudeqt/claudeqt-libs/kf5syntaxhighlighting-qt6/ (a sibling
# of this repo per phase-1.md §2 build-workspace layout), so its debhelper
# staging directories never appear here. Only the main claudeqt source
# package writes into this tree's debian/.
debian/.debhelper/
debian/files
debian/debhelper-build-stamp
debian/*.debhelper.log
debian/*.substvars
debian/tmp/
debian/claudeqt/
debian/claudeqt-remote/
debian/claudeqt-common/

